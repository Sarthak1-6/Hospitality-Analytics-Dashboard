      <aliases enabled='yes' />
      <column caption='occupancy ' datatype='real' name='[Calculation_1970324880027856896]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([successful_bookings])/SUM([capacity])' />
      </column>
      <column caption='Total cancelled bookings' datatype='integer' name='[Calculation_1970324880047398915]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;IF [booking_status] = &quot;Cancelled&quot;&#13;&#10;THEN [booking_id]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Cancellation %' datatype='real' name='[Calculation_1970324880047812612]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1970324880047398915]/COUNT([booking_id])' />
      </column>
      <column caption='Day type ' datatype='string' name='[Calculation_1970324880271237128]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATENAME(&apos;weekday&apos;, [check_in_date]) IN (&quot;Saturday&quot;,&quot;Sunday&quot;)&#13;&#10;THEN &quot;Weekend&quot;&#13;&#10;ELSE &quot;Weekday&quot;&#13;&#10;END' />
      </column>
      <column caption='ADR' datatype='real' name='[Calculation_1970324880629157897]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([revenue_realized])/SUM([successful_bookings])' />
      </column>
      <column caption='RevPAR' datatype='real' name='[Calculation_1970324880630370314]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([revenue_realized])/SUM([capacity])' />
      </column>
